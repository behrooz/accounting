APP_ENV=dev
APP_PORT=8080
APP_CORS_ORIGIN=*

MYSQL_DSN=accounting:accounting@tcp(localhost:3306)/accounting?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

JWT_SECRET=change-me-in-production

# sms.ir OTP login (https://api.sms.ir/v1/send/verify)
# Create a verify template in sms.ir panel, e.g. "کد ورود شما: #CODE#"
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=0
SMS_IR_PARAM_NAME=CODE
